#version 460
#extension GL_EXT_ray_tracing : require

layout(push_constant) uniform PushConstants
{
	uvec2 target_address;
	uvec2 decoy_address;
} pc;

struct CallableData
{
	uvec2 address;
};

layout(location = 0) callableDataInEXT CallableData callable_data;

void main()
{
	callable_data.address = pc.target_address;
}
