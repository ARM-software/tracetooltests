{
	"name": "vulkan_aztec_simulator_slow_compute",
	"description": "Isolated Aztec compute shader that is slow in the SPIR-V simulator",
	"settings": {
		"vulkan_variant": {
			"description": "Set Vulkan variant",
			"type": "selection",
			"options": [ "1.0", "1.1", "1.2", "1.3" ]
		}
	},
	"capabilities": {
		"non_interactive": {
			"default": true,
			"modifiable": false
		},
		"frameless": {
			"default": true,
			"modifiable": true
		},
		"fixed_framerate": {
			"default": true,
			"modifiable": false
		},
		"gpu_frame_deterministic": {
			"default": true,
			"modifiable": false
		},
		"gpu_fully_deterministic": {
			"default": true,
			"modifiable": false
		}
	}
}
